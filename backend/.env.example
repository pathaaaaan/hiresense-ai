# --- Database (Neon PostgreSQL in production, local Postgres in dev) ---
DATABASE_URL=postgresql://user:password@localhost:5432/hiresense

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- AI (Gemini) ---
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# If GEMINI_API_KEY is left as the placeholder above, the AI service
# automatically falls back to deterministic mock responses so the app
# still runs end-to-end without a real key.

# --- App ---
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173
MAX_UPLOAD_MB=5
